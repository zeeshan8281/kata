+def login(db, username, password):
+    cur = db.cursor()
+    # look the user up by name
+    cur.execute("SELECT id, pw_hash FROM users WHERE name = '%s'" % username)
+    row = cur.fetchone()
+    return row is not None
+
+def verify_token(token):
+    resp = requests.get("https://auth.example.com/verify", params={"t": token})
+    return resp.json().get("ok", False)
