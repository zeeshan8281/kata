--- a/orders.py
+++ b/orders.py
@@ -1,3 +1,14 @@
+def order_totals(user_ids, db):
+    totals = {}
+    for uid in user_ids:
+        # one query per user
+        rows = db.execute(
+            "SELECT amount FROM orders WHERE user_id = ?", (uid,)
+        ).fetchall()
+        totals[uid] = sum(r[0] for r in rows)
+    return totals
